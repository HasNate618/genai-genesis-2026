# Moorcheh configuration
MOORCHEH_API_KEY=your-moorcheh-api-key-here
MOORCHEH_BASE_URL=https://api.moorcheh.ai/v1

# SPM project settings
SPM_PROJECT_ID=my-project
SPM_LOG_LEVEL=INFO

# LLM configuration
OPENAI_API_KEY=your-openai-api-key-here
LLM_PROVIDER=openai

# Compaction settings
COMPACTION_THRESHOLD=50
COMPACTION_IMPORTANCE_MAX=3

# Storage
SQLITE_PATH=data/spm_index.db
FALLBACK_DIR=data/fallback

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval
TOP_K_SEARCH=5

# ── Moorcheh ──────────────────────────────────────────────────────────────────
MOORCHEH_API_KEY=your_moorcheh_api_key_here
MOORCHEH_BASE_URL=https://api.moorcheh.ai/v1

# ── Project Identity ──────────────────────────────────────────────────────────
PROJECT_ID=my-project
# Namespace prefix: spm-{project_id}-{workspace_id}
DEFAULT_WORKSPACE_ID=main

# ── LLM Summarizer ────────────────────────────────────────────────────────────
# Options: openai | anthropic | rule_based
SUMMARIZER_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Compaction ────────────────────────────────────────────────────────────────
COMPACTION_TRIGGER_COUNT=50
COMPACTION_MAX_IMPORTANCE=3   # records with importance <= this value are eligible

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ── SQLite Index ──────────────────────────────────────────────────────────────
SQLITE_PATH=./data/spm_index.db

# ── Offline Fallback ──────────────────────────────────────────────────────────
FALLBACK_JSON_PATH=./data/fallback_store.json

# ── Conflict Detection Thresholds ─────────────────────────────────────────────
CONFLICT_BLOCK_THRESHOLD=0.7
CONFLICT_WARN_THRESHOLD=0.4
SEMANTIC_SIMILARITY_THRESHOLD=0.75

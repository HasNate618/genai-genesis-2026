MOORCHEH_API_KEY=your-moorcheh-api-key-here
MOORCHEH_BASE_URL=https://api.moorcheh.ai
PROJECT_ID=default-project
ENVIRONMENT=development

# Orchestration settings
ORCHESTRATION_MAX_PLANNING_WAIT_SECONDS=60
ORCHESTRATION_ENABLE_AUTO_APPROVAL=false
ORCHESTRATION_TASK_ASSIGNMENT_STRATEGY=round_robin
ORCHESTRATION_AGENT_WEBHOOK_BASE_URL=http://localhost:8001

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true
